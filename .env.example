# Copy this file to .env and fill values locally.
# Never commit real API keys.

INKPERSONA_ENV=development
INKPERSONA_API_HOST=127.0.0.1
INKPERSONA_API_PORT=8000
INKPERSONA_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
INKPERSONA_MAX_UPLOAD_MB=12
INKPERSONA_REQUEST_TIMEOUT_SECONDS=90
INKPERSONA_LOG_LEVEL=info

OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_OUTPUT_TOKENS=3500

INKPERSONA_STORAGE_DIR=./storage
INKPERSONA_REPORT_RETENTION_DAYS=0

VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_APP_NAME=InkPersona
VITE_MAX_UPLOAD_MB=12
VITE_ENABLE_MOCK_ANALYSIS=true
